{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Train model",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "train_model.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Streamlit",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\streamlit.exe",
      "args": [
        "run",
        "app.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}